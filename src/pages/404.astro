---
import Layout from '../layouts/Layout.astro';

const homeHref = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/';
---

<Layout
	title="Page Not Found — ScriptFlow"
	description="This page could not be found."
	canonicalPath="/404"
>
	<div class="py-20 text-center">
		<h1 class="text-5xl text-[#221B10]">404</h1>
		<p class="mt-5 text-[#4A4234]">
			That page doesn't exist.
			<a href={homeHref} class="text-[#B8860B] underline transition hover:text-[#C9982E]">Back to the homepage</a>.
		</p>
	</div>
</Layout>
