---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonicalPath?: string;
}

const { title, description, canonicalPath = '/' } = Astro.props;
// Astro.site is the bare origin (e.g. https://toprmrproducer.github.io) and does
// NOT include the configured `base` path, so it must be joined in manually or
// canonical/og:url links lose the /scriptflow segment.
const siteOrigin = Astro.site?.toString().replace(/\/+$/, '') ?? 'https://toprmrproducer.github.io';
// BASE_URL may or may not have a trailing slash depending on Astro version;
// normalize to always have exactly one trailing slash before joining paths.
const base = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/';
const normalizedCanonicalPath = canonicalPath === '/' ? '' : canonicalPath.replace(/^\//, '');
const canonical = `${siteOrigin}${base}${normalizedCanonicalPath}`;
const faviconHref = `${base}favicon.svg`;
const homeHref = base;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-white text-[#4A4234] antialiased">
		<header class="border-b border-[#EAE4D6] bg-white">
			<nav class="mx-auto flex max-w-[820px] items-center justify-between px-6 py-5">
				<a href={homeHref} class="font-[Sora] text-xl font-extrabold tracking-tight text-[#221B10]">
					ScriptFlow
				</a>
				<span class="hidden text-[15px] font-semibold uppercase tracking-wide text-[#C9982E] sm:inline">
					On-device transcription
				</span>
			</nav>
		</header>

		<!--
			Reserved AdSense slots. Every slot below is an EMPTY container with the
			`ad-slot` class, so `.ad-slot:empty { display:none }` keeps it invisible
			and zero-height until a real <ins class="adsbygoogle"> is pasted inside.
			This avoids empty-placeholder boxes (which can hurt AdSense approval) and
			avoids layout shift once a unit fills in.
		-->

		<!-- Top leaderboard: centered directly below the header, above main content. -->
		<div class="ad-slot ad-leaderboard mx-auto mt-6 px-6" data-ad-slot="leaderboard" style="max-width:970px;min-height:0">
			<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
		</div>

		<!--
			The content column is intentionally narrow (max 820px) and centered so
			the page keeps genuinely empty left/right gutters on desktop. The two
			sticky skyscraper <aside> rails sit in those gutters at >=1280px only;
			below that they are hidden and the column simply centers. Do NOT fill
			the gutters with content — they are reserved ad space.
		-->
		<div class="mx-auto flex w-full max-w-[1400px] items-start justify-center gap-6 px-4 xl:px-0">
			<!-- Left skyscraper rail (>=1280px only). -->
			<aside class="sticky top-[120px] hidden w-[160px] shrink-0 xl:block" aria-hidden="true">
				<div class="ad-slot ad-skyscraper" data-ad-slot="skyscraper-left" style="width:160px;min-height:0">
					<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
				</div>
			</aside>

			<main class="w-full max-w-[820px] px-6 pt-16 pb-24 sm:pt-20">
				<slot />

				<!-- Bottom in-article slot: centered, just above the footer. -->
				<div class="ad-slot ad-in-article mx-auto mt-16" data-ad-slot="in-article" style="max-width:728px;min-height:0">
					<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
				</div>
			</main>

			<!-- Right skyscraper rail (>=1280px only). -->
			<aside class="sticky top-[120px] hidden w-[160px] shrink-0 xl:block" aria-hidden="true">
				<div class="ad-slot ad-skyscraper" data-ad-slot="skyscraper-right" style="width:160px;min-height:0">
					<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
				</div>
			</aside>
		</div>

		<footer class="mt-4 border-t border-[#EAE4D6] bg-[#FAF8F3]">
			<div class="mx-auto max-w-[820px] px-6 py-12 text-base text-[#4A4234]">
				<p>
					Every transcription runs locally in your browser. Nothing you upload
					is ever sent to a server.
				</p>
				<div class="mt-5 flex gap-7 text-[15px] font-medium">
					<a href={`${base}about`} class="py-2 text-[#4A4234] transition hover:text-[#B8860B]">About</a>
					<a href={`${base}privacy`} class="py-2 text-[#4A4234] transition hover:text-[#B8860B]">Privacy Policy</a>
					<a href={`${base}faq`} class="py-2 text-[#4A4234] transition hover:text-[#B8860B]">FAQ</a>
				</div>
				<p class="mt-5 text-sm text-[#8A7E68]">&copy; {new Date().getFullYear()} ScriptFlow</p>
			</div>
		</footer>
	</body>
</html>
