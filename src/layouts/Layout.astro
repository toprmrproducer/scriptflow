---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonicalPath?: string;
}

const { title, description, canonicalPath = '/' } = Astro.props;
// Astro.site is the bare origin (e.g. https://toprmrproducer.github.io) and does
// NOT include the configured `base` path, so it must be joined in manually or
// canonical/og:url links lose the /scriptflow segment.
const siteOrigin = Astro.site?.toString().replace(/\/+$/, '') ?? 'https://toprmrproducer.github.io';
// BASE_URL may or may not have a trailing slash depending on Astro version;
// normalize to always have exactly one trailing slash before joining paths.
const base = import.meta.env.BASE_URL.replace(/\/+$/, '') + '/';
const normalizedCanonicalPath = canonicalPath === '/' ? '' : canonicalPath.replace(/^\//, '');
const canonical = `${siteOrigin}${base}${normalizedCanonicalPath}`;
const faviconHref = `${base}favicon.svg`;
const homeHref = base;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-[#FAF6EC] text-[#5C4F3D] antialiased">
		<header class="border-b border-[#E8DFC8]">
			<nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-5">
				<a href={homeHref} class="font-[Fraunces] text-xl font-semibold tracking-tight text-[#2B2013]">
					ScriptFlow
				</a>
				<span class="hidden text-xs font-medium uppercase tracking-wide text-[#C9982E] sm:inline">
					On-device transcription
				</span>
			</nav>
		</header>
		<main class="mx-auto max-w-4xl px-6 py-14">
			<slot />
		</main>
		<footer class="mt-24 border-t border-[#E8DFC8]">
			<div class="mx-auto max-w-4xl px-6 py-10 text-sm text-[#5C4F3D]">
				<p>
					Every transcription runs locally in your browser. Nothing you upload
					is ever sent to a server.
				</p>
				<div class="mt-4 flex gap-6">
					<a href={`${base}about`} class="hover:text-[#B8860B]">About</a>
					<a href={`${base}privacy`} class="hover:text-[#B8860B]">Privacy Policy</a>
					<a href={`${base}faq`} class="hover:text-[#B8860B]">FAQ</a>
				</div>
				<p class="mt-4 text-[#8A7D66]">&copy; {new Date().getFullYear()} ScriptFlow</p>
			</div>
		</footer>
	</body>
</html>
